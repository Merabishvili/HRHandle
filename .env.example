# Supabase project URL — found in Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — NEVER expose in client code, server-side only
# Rotate immediately if accidentally committed to git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (added in Phase 4)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
